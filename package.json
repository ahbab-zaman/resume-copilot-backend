{
  "name": "ai-resume-job-pilot-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/server.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "deploy": "npm run migrate && npm run build",
    "start": "node dist/server.js",
    "migrate": "sequelize-cli db:migrate --config sequelize.config.cjs --migrations-path migrations",
    "migrate:undo": "sequelize-cli db:migrate:undo --config sequelize.config.cjs --migrations-path migrations"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jose": "^5.10.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.5",
    "sequelize-cli": "^6.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
